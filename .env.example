# ─────────────────────────────────────────────
# veteran-agent-starter — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it contains your API key.
#
# cp .env.example .env

# Your Anthropic API key.
# Get one free at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: displayed in the chat UI header and health endpoint.
# Change this to your agent's name.
AGENT_NAME=My Agent

# Port (Railway sets this automatically — don't change for production)
# PORT=3000
